#!/bin/sh
# Ruleaza aceleasi verificari ca CI (lint + typecheck + test) INAINTE de push,
# ca sa nu mai vezi CI rosu dupa ce ai impins. Activat prin `core.hooksPath`
# (setat automat de scriptul `prepare` din package.json la `npm install`).
#
# Sari peste — rar, cand chiar stii ce faci: git push --no-verify
set -e

echo "▶ pre-push: lint..."
npm run lint

echo "▶ pre-push: typecheck..."
npm run typecheck

echo "▶ pre-push: test..."
npm test

echo "✓ pre-push OK"
