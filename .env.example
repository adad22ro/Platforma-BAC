# Variabile de mediu — Platformă BAC
# Copiază acest fișier în `.env.local` și completează valorile reale.
# NICIODATĂ nu comite `.env.local` în Git.
#
# Variabilele sunt validate la pornirea serverului (lib/env.ts). Dacă lipsește
# una obligatorie, serverul crapă imediat cu mesaj clar. Adaugi o variabilă nouă?
# Actualizează și schema din lib/env.ts.

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Clerk (autentificare) ───────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Stripe (plăți) ─────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=

# ─── Panou de monitorizare (/admin) ─────────────────────────
# Email-uri cu acces la /admin, separate prin virgula.
ADMIN_EMAILS=
# Token Vercel pentru deploy-uri + loguri (vercel.com/account/tokens).
VERCEL_API_TOKEN=
# Optional: doar daca proiectul e intr-o echipa Vercel (nu cont personal).
VERCEL_TEAM_ID=
# Optional: numele proiectului Vercel (default: platforma-bac).
VERCEL_PROJECT_NAME=

# ─── Monitorizare / alerte ──────────────────────────────────
# URL webhook Discord pentru alerte instant la erori critice (webhook plata,
# checkout esuat). Optional — daca lipseste, erorile doar se logeaza in DB.
# Creezi: Discord → Server Settings → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_ALERT_WEBHOOK_URL=

# ─── Aplicație ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
