# ci
DOTENV_VAULT_CI=""
DOTENV_VAULT_CI_VERSION=2

# staging
DOTENV_VAULT_STAGING=""
DOTENV_VAULT_STAGING_VERSION=2

# production
DOTENV_VAULT_PRODUCTION=""
DOTENV_VAULT_PRODUCTION_VERSION=2

# development
DOTENV_VAULT_DEVELOPMENT=""
DOTENV_VAULT_DEVELOPMENT_VERSION=2

#/----------------settings/metadata-----------------/
DOTENV_VAULT="vlt_4c5788be701a056e10b65d1b8429bd59ec833920d95b17b81dee50fe28e885d3"
DOTENV_API_URL="https://vault.dotenv.org"
DOTENV_CLI="npx dotenv-vault@latest"
